# ======================================
# Edge-AI Security Dashboard
# Environment Variables Template
# ======================================

# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ---------------------------------------
# Gemini AI API (Optional)
# ---------------------------------------
# Required for enhanced AI capabilities
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ---------------------------------------
# Application Settings
# ---------------------------------------
# Base URL for the application (used for deployment)
APP_URL="http://localhost:5173"

# ---------------------------------------
# Backend Settings (Python Flask)
# ---------------------------------------
# Flask server port
FLASK_PORT=5000

# Camera source (0 for default webcam, or path to video file)
CAMERA_SOURCE=0

# YOLOv8 Model (n=nano, s=small, m=medium, l=large, x=xlarge)
YOLO_MODEL="yolov8n.pt"

# Detection confidence threshold (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.5

# Alert confidence threshold (0.0 - 1.0)
ALERT_THRESHOLD=0.7

# ---------------------------------------
# Frontend Settings (React + Vite)
# ---------------------------------------
# Vite dev server port
VITE_PORT=5173

# API endpoint for backend
VITE_API_URL="http://localhost:5000"

