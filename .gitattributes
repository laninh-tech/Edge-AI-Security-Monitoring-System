# Git Attributes for Edge-AI Security Dashboard

# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.py text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Model files - mark as binary
*.pt binary
*.pth binary
*.onnx binary
*.pb binary
*.h5 binary

# Media files - mark as binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.mp4 binary
*.mov binary
*.avi binary
*.webm binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.rar binary

# Database files
*.db binary
*.sqlite binary
*.sqlite3 binary

# Git LFS tracking (if used)
# Uncomment and configure as needed
# *.pt filter=lfs diff=lfs merge=lfs -text
# *.pth filter=lfs diff=lfs merge=lfs -text
